<section class="page-header">
  <h1>Manage Reviews</h1>
  <a href="/admin" class="btn btn-outline btn-sm">&larr; Dashboard</a>
</section>

<section class="section">
  <% if (reviews.length > 0) { %>
    <div class="card-list">
      <% reviews.forEach(review => { %>
        <div class="card card-horizontal">
          <div class="card-body">
            <div class="card-header-row">
              <strong><%= review.first_name %> <%= review.last_name %></strong>
              (<%= review.email %>)
              <span class="card-badge"><%= review.review_type %></span>
              <div class="stars">
                <% for (let i = 0; i < review.rating; i++) { %>&#9733;<% } %>
                <% for (let i = review.rating; i < 5; i++) { %>&#9734;<% } %>
              </div>
              <% if (review.is_approved) { %>
                <span class="status-badge status-completed">Approved</span>
              <% } else if (review.is_flagged) { %>
                <span class="status-badge status-cancelled">Flagged</span>
              <% } else { %>
                <span class="status-badge status-submitted">Pending</span>
              <% } %>
            </div>
            <p><%= review.content %></p>
            <span class="card-date"><%= new Date(review.created_at).toLocaleDateString() %></span>
          </div>
          <div class="card-actions">
            <% if (!review.is_approved) { %>
              <form action="/admin/reviews/<%= review.id %>/approve" method="POST" class="inline-form">
                <button type="submit" class="btn btn-sm btn-primary">Approve</button>
              </form>
            <% } %>
            <% if (!review.is_flagged) { %>
              <form action="/admin/reviews/<%= review.id %>/flag" method="POST" class="inline-form">
                <button type="submit" class="btn btn-sm btn-warning">Flag</button>
              </form>
            <% } %>
            <form action="/admin/reviews/<%= review.id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('Delete this review permanently?')">
              <button type="submit" class="btn btn-sm btn-danger">Delete</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <p class="empty-message">No reviews yet.</p>
  <% } %>
</section>
