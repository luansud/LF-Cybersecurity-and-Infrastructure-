<section class="page-header">
  <h1><%= article ? 'Edit Article' : 'New Article' %></h1>
  <a href="/admin/news" class="btn btn-outline btn-sm">&larr; Back to News</a>
</section>

<section class="section">
  <form action="<%= article ? '/admin/news/' + article.id : '/admin/news' %>" method="POST" class="form form-card">
    <div class="form-group">
      <label for="title">Title</label>
      <input type="text" id="title" name="title" required value="<%= article ? article.title : '' %>" placeholder="Article title">
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="category">Category</label>
        <select id="category" name="category" required>
          <option value="cyber_world" <%= article && article.category === 'cyber_world' ? 'selected' : '' %>>Cyber Around the World</option>
          <option value="articles" <%= article && article.category === 'articles' ? 'selected' : '' %>>My Articles</option>
          <option value="course_news" <%= article && article.category === 'course_news' ? 'selected' : '' %>>Course News</option>
        </select>
      </div>
      <div class="form-group">
        <label for="image_url">Image URL (optional)</label>
        <input type="url" id="image_url" name="image_url" value="<%= article && article.image_url ? article.image_url : '' %>" placeholder="https://example.com/image.jpg">
      </div>
    </div>

    <div class="form-group">
      <label for="summary">Summary (optional)</label>
      <textarea id="summary" name="summary" rows="2" placeholder="Brief preview text..."><%= article ? article.summary || '' : '' %></textarea>
    </div>

    <div class="form-group">
      <label for="content">Content</label>
      <textarea id="content" name="content" rows="12" required placeholder="Full article content..."><%= article ? article.content : '' %></textarea>
    </div>

    <button type="submit" class="btn btn-primary"><%= article ? 'Update Article' : 'Create Article' %></button>
  </form>
</section>
