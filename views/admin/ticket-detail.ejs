<section class="page-header">
  <h1>Ticket #<%= ticket.id %>: <%= ticket.subject %></h1>
  <a href="/admin/tickets" class="btn btn-outline btn-sm">&larr; Back</a>
</section>

<section class="section">
  <div class="detail-card">
    <div class="detail-meta">
      <span class="status-badge status-<%= ticket.status %>"><%= ticket.status.replace('_', ' ') %></span>
      <span class="card-badge"><%= ticket.category %></span>
      <span class="priority-<%= ticket.priority %>"><%= ticket.priority %> priority</span>
      <span class="card-date">From: <strong><%= ticket.first_name %> <%= ticket.last_name %></strong> (<%= ticket.email %>)</span>
      <span class="card-date">Opened: <%= new Date(ticket.created_at).toLocaleDateString() %></span>
    </div>

    <!-- Status Update -->
    <div class="admin-action-bar">
      <form action="/admin/tickets/<%= ticket.id %>/status" method="POST" class="inline-form">
        <label for="status"><strong>Update Status:</strong></label>
        <select name="status" id="status">
          <option value="open" <%= ticket.status === 'open' ? 'selected' : '' %>>Open</option>
          <option value="in_progress" <%= ticket.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
          <option value="resolved" <%= ticket.status === 'resolved' ? 'selected' : '' %>>Resolved</option>
          <option value="closed" <%= ticket.status === 'closed' ? 'selected' : '' %>>Closed</option>
        </select>
        <button type="submit" class="btn btn-sm btn-primary">Update</button>
      </form>
    </div>

    <div class="detail-body">
      <h3>Original Message</h3>
      <p><%= ticket.message %></p>
    </div>
  </div>
</section>

<section class="section">
  <h2 class="section-title">Conversation</h2>

  <div class="conversation">
    <% if (responses.length > 0) { %>
      <% responses.forEach(resp => { %>
        <div class="message-bubble <%= resp.role === 'admin' ? 'message-admin' : 'message-user' %>">
          <div class="message-header">
            <strong><%= resp.first_name %> <%= resp.last_name %></strong>
            <% if (resp.role === 'admin') { %><span class="card-badge">Admin</span><% } %>
            <span class="card-date"><%= new Date(resp.created_at).toLocaleString() %></span>
          </div>
          <p><%= resp.message %></p>
        </div>
      <% }) %>
    <% } else { %>
      <p class="empty-message">No responses yet.</p>
    <% } %>
  </div>

  <form action="/admin/tickets/<%= ticket.id %>/respond" method="POST" class="form">
    <div class="form-group">
      <label for="message">Respond</label>
      <textarea id="message" name="message" rows="3" required placeholder="Type your response..."></textarea>
    </div>
    <button type="submit" class="btn btn-primary">Send Response</button>
  </form>
</section>
