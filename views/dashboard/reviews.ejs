<section class="page-header">
  <h1>My Reviews</h1>
  <a href="/reviews/new" class="btn btn-primary">Write a Review</a>
</section>

<section class="section">
  <% if (reviews.length > 0) { %>
    <div class="card-list">
      <% reviews.forEach(review => { %>
        <div class="card card-horizontal">
          <div class="card-body">
            <div class="card-header-row">
              <div class="stars">
                <% for (let i = 0; i < review.rating; i++) { %>&#9733;<% } %>
                <% for (let i = review.rating; i < 5; i++) { %>&#9734;<% } %>
              </div>
              <span class="card-badge"><%= review.review_type %></span>
              <% if (review.is_approved) { %>
                <span class="status-badge status-completed">Approved</span>
              <% } else if (review.is_flagged) { %>
                <span class="status-badge status-cancelled">Flagged</span>
              <% } else { %>
                <span class="status-badge status-submitted">Pending</span>
              <% } %>
            </div>
            <p><%= review.content %></p>
            <span class="card-date"><%= new Date(review.created_at).toLocaleDateString() %></span>
          </div>
          <div class="card-actions">
            <a href="/reviews/<%= review.id %>/edit" class="btn btn-sm btn-outline">Edit</a>
            <form action="/reviews/<%= review.id %>/delete" method="POST" class="inline-form" onsubmit="return confirm('Delete this review?')">
              <button type="submit" class="btn btn-sm btn-danger">Delete</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="empty-state">
      <p>You haven't written any reviews yet.</p>
      <a href="/reviews/new" class="btn btn-primary">Write Your First Review</a>
    </div>
  <% } %>
</section>
