<section class="page-header">
  <h1>My Consultations</h1>
  <a href="/company/consultations/new" class="btn btn-primary">Request Consultation</a>
</section>

<section class="section">
  <% if (consultations.length > 0) { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Title</th>
          <th>Priority</th>
          <th>Status</th>
          <th>Created</th>
          <th>Last Updated</th>
        </tr>
      </thead>
      <tbody>
        <% consultations.forEach(c => { %>
          <tr>
            <td><a href="/company/consultations/<%= c.id %>">#<%= c.id %></a></td>
            <td><a href="/company/consultations/<%= c.id %>"><%= c.title %></a></td>
            <td><span class="priority-<%= c.priority %>"><%= c.priority %></span></td>
            <td><span class="status-badge status-<%= c.status %>"><%= c.status.replace('_', ' ') %></span></td>
            <td><%= new Date(c.created_at).toLocaleDateString() %></td>
            <td><%= new Date(c.updated_at).toLocaleDateString() %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <div class="empty-state">
      <p>No consultations yet.</p>
      <a href="/company/consultations/new" class="btn btn-primary">Request Your First Consultation</a>
    </div>
  <% } %>
</section>
