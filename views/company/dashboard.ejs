<section class="page-header">
  <h1>Welcome, <%= company.company_name %></h1>
  <p class="page-subtitle">Company Dashboard</p>
</section>

<section class="section">
  <div class="dashboard-grid">
    <a href="/company/consultations/new" class="dashboard-card card-accent">
      <div class="dashboard-icon">&#128640;</div>
      <h3>New Consultation</h3>
      <p>Request a cybersecurity assessment</p>
    </a>

    <a href="/company/consultations" class="dashboard-card">
      <div class="dashboard-icon">&#128203;</div>
      <h3>Consultations</h3>
      <p><%= activeConsultations.length %> active</p>
    </a>

    <a href="/tickets/my" class="dashboard-card">
      <div class="dashboard-icon">&#127915;</div>
      <h3>Support Tickets</h3>
      <p><%= tickets.filter(t => t.status !== 'closed').length %> open</p>
    </a>

    <a href="/reviews/my" class="dashboard-card">
      <div class="dashboard-icon">&#9733;</div>
      <h3>My Reviews</h3>
      <p><%= reviews.length %> review<%= reviews.length !== 1 ? 's' : '' %></p>
    </a>

    <a href="/company/profile" class="dashboard-card">
      <div class="dashboard-icon">&#127970;</div>
      <h3>Company Profile</h3>
      <p>View and edit company info</p>
    </a>
  </div>
</section>

<% if (activeConsultations.length > 0) { %>
<section class="section">
  <h2 class="section-title">Active Consultations</h2>
  <table class="data-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Title</th>
        <th>Priority</th>
        <th>Status</th>
        <th>Last Updated</th>
      </tr>
    </thead>
    <tbody>
      <% activeConsultations.forEach(c => { %>
        <tr>
          <td><a href="/company/consultations/<%= c.id %>">#<%= c.id %></a></td>
          <td><a href="/company/consultations/<%= c.id %>"><%= c.title %></a></td>
          <td><span class="priority-<%= c.priority %>"><%= c.priority %></span></td>
          <td><span class="status-badge status-<%= c.status %>"><%= c.status.replace('_', ' ') %></span></td>
          <td><%= new Date(c.updated_at).toLocaleDateString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>
<% } %>
